{
  "name": "@package/api",
  "version": "1.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/index.ts"
  },
  "scripts": {
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "format": "eslint . --ext ts,tsx --fix",
    "webhooks": "tsx src/webhooks/index.ts",
    "webhooks:dev": "tsx watch src/webhooks/index.ts",
    "dev": "DOTENV_CONFIG_PATH=../../.env tsx watch src/jobs/chat/chat.worker.ts",
    "typecheck": "tsc --noEmit",
    "worker:chat": "tsx src/jobs/chat/chat.worker.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.975.0",
    "@aws-sdk/s3-request-presigner": "^3.975.0",
    "@genkit-ai/googleai": "^1.18.0",
    "@package/auth": "workspace:*",
    "@package/db": "workspace:*",
    "@package/email": "workspace:*",
    "@package/utils": "workspace:*",
    "@package/validations": "workspace:*",
    "@trpc/server": "11.1.2",
    "bullmq": "^5.66.1",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "genkit": "^1.18.0",
    "genkitx-deepseek": "^1.0.1",
    "genkitx-mistral": "^0.23.0",
    "googleapis": "^170.1.0",
    "ioredis": "^5.8.2",
    "mongoose": "^9.1.5",
    "papaparse": "^5.5.3",
    "superjson": "2.2.1",
    "twilio": "^5.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@package/eslint-config": "workspace:*",
    "@package/prettier-config": "workspace:*",
    "@package/typescript-config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/papaparse": "^5.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}
