{
  "name": "alpadev_ai_monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:prod": "cd apps/frontend && pnpm build",
    "clean": "find . -name node_modules -o -name .next -o -name .turbo -o -name dist -type d -prune | head -20 | xargs rm -rf",
    "db:push": "turbo db:push",
    "db:studio": "turbo db:studio",
    "dev": "docker compose up redis -d && turbo dev",
    "dev:no-redis": "turbo dev",
    "format": "prettier --write \"**/*.{js,cjs,mjs,ts,tsx,md,json}\" --ignore-path .gitignore",
    "lint": "turbo lint && manypkg check",
    "start": "cd apps/frontend && pnpm start",
    "start:turbo": "turbo start",
    "typecheck": "turbo typecheck"
  },
  "prettier": "@package/prettier-config",
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@manypkg/cli": "^0.22.0",
    "@package/prettier-config": "workspace:*",
    "@turbo/gen": "^2.3.3",
    "prettier": "^3.4.2",
    "turbo": "^2.5.8"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22"
  }
}
